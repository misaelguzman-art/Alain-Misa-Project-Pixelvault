<h1>4. Integración del Backend en NodeJS</h1>
<p>
    El backend está construido modularmente utilizando **Express** y **tedious** (a través de <code>mssql</code>). A continuación se destacan los componentes clave:
</p>

<h3>4.1 Enrutamiento Dinámico (Backend/middleware.js)</h3>
<p>
    Este middleware inyecta dinámicamente el Connection Pool correspondiente al país en la solicitud (<code>req.dbPool</code>):
</p>
<pre>
const { poolBolivia, poolPeru } = require('./database');

module.exports = (req, res, next) => {
    const pais = req.headers['x-pais'] || req.query.pais || 'bolivia';

    if (pais.toLowerCase() === 'peru') {
        req.dbPool = poolPeru;
    } else {
        req.dbPool = poolBolivia; // Por defecto Bolivia (Central)
    }
    
    next();
};
</pre>

<h3>4.2 Conexión Multi-Pool (Backend/database.js)</h3>
<p>
    Levanta de forma asíncrona dos Connection Pools individuales a las bases de datos de Bolivia y Perú simultáneamente:
</p>
<pre>
const sql = require('mssql');

const configBolivia = {
    user: 'Admin', 
    password: 'admin',
    server: 'LAPTOP-GGCKNFU6', 
    database: 'BD2_tienda',
    options: { encrypt: false, trustServerCertificate: true }
};

const configPeru = {
    user: 'Admin', 
    password: 'admin',
    server: 'DESKTOP-44CCO3Q', 
    database: 'NodoSucursal',
    options: { encrypt: false, trustServerCertificate: true }
};

const poolBolivia = new sql.ConnectionPool(configBolivia);
const poolPeru = new sql.ConnectionPool(configPeru);

const poolBoliviaPromise = poolBolivia.connect()
    .then(pool => { console.log('✅ Conectado a Bolivia (Central)'); return pool; });

const poolPeruPromise = poolPeru.connect()
    .then(pool => { console.log('✅ Conectado a Perú (Sucursal)'); return pool; });

module.exports = { 
    sql, 
    poolBolivia,
    poolPeru,
    poolBoliviaPromise,
    poolPeruPromise
};
</pre>

